# Copy this file's contents into your shell (or a .env loader of your choice)
# before running the backend. Spring Boot reads these as environment variables
# via application.yml's ${VAR_NAME} placeholders.

GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GEMINI_API_KEY=your-gemini-api-key
JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# Optional but recommended: real photos of the actual place (Louisa Point,
# Charlotte Lake, etc) instead of generic stock photos. From the same Google
# Cloud project as your OAuth client: enable "Places API" (legacy) at
# https://console.cloud.google.com/apis/library/places-backend.googleapis.com
# then create an API key at https://console.cloud.google.com/apis/credentials
# Note: requires billing to be enabled on the project (Places API has a free
# monthly quota, but Google still requires a billing account attached).
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Optional fallback stock-photo source, used only when Google Places has no
# photo for a given place. Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-api-key
